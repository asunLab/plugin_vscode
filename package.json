{
  "icon": "images/logo.png",
  "name": "asun-vscode",
  "displayName": "ASUN Support",
  "description": "Language support for ASUN (Array-Schema Unified Notation) format — syntax highlighting, formatting, compression, error diagnostics, and field hints",
  "version": "0.1.1",
  "license": "MIT",
  "publisher": "Athan",
  "repository": {
    "type": "git",
    "url": "https://github.com/asunLab/plugin_vscode.git",
    "directory": "plugin_vscode"
  },
  "homepage": "https://github.com/asunLab/plugin_vscode#readme",
  "bugs": {
    "url": "https://github.com/asunLab/plugin_vscode/issues"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "activationEvents": [
    "onLanguage:asun"
  ],
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "keywords": [
    "asun",
    "schema",
    "serialization",
    "formatter",
    "language-server"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "asun",
        "aliases": [
          "ASUN",
          "asun"
        ],
        "extensions": [
          ".asun"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "asun",
        "scopeName": "source.asun",
        "path": "./syntaxes/asun.tmLanguage.json"
      },
      {
        "scopeName": "markdown.asun.codeblock",
        "path": "./syntaxes/asun.markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.asun": "asun"
        }
      }
    ],
    "commands": [
      {
        "command": "asun.format",
        "title": "ASUN: Format (Beautify)",
        "enablement": "resourceLangId == asun"
      },
      {
        "command": "asun.compress",
        "title": "ASUN: Compress (Minify)",
        "enablement": "resourceLangId == asun"
      },
      {
        "command": "asun.toJSON",
        "title": "ASUN: Convert to JSON",
        "enablement": "resourceLangId == asun"
      },
      {
        "command": "asun.fromJSON",
        "title": "ASUN: Convert JSON to ASUN"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "asun.format",
          "when": "resourceLangId == asun",
          "group": "1_modification@1"
        },
        {
          "command": "asun.compress",
          "when": "resourceLangId == asun",
          "group": "1_modification@2"
        },
        {
          "command": "asun.toJSON",
          "when": "resourceLangId == asun",
          "group": "1_modification@3"
        },
        {
          "command": "asun.fromJSON",
          "when": "resourceLangId == json",
          "group": "1_modification@1"
        }
      ]
    },
    "configuration": {
      "title": "ASUN",
      "properties": {
        "asun.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the lsp-asun binary. If empty, uses bundled or PATH."
        },
        "asun.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show field name hints in data tuples."
        }
      }
    }
  },
  "markdown": {
    "previewScripts": [
      "./preview/asun-preview.js"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build-lsp && npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "build-lsp": "cd ../lsp-asun && zig build -Drelease=true && mkdir -p ../plugin_vscode/server && cp zig-out/bin/lsp-asun ../plugin_vscode/server/lsp-asun",
    "deploy-lsp": "npm run build-lsp && cp server/lsp-asun \"$(node -e \"const p=require('path'),os=require('os'),f=require('fs');const ext=p.join(os.homedir(),'.vscode','extensions');const d=f.readdirSync(ext).find(x=>x.startsWith('asun.asun-vscode'));if(d){console.log(p.join(ext,d,'server','lsp-asun'))}\")\""
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
