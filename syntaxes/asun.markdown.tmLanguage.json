{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ASUN Markdown Injection",
  "scopeName": "markdown.asun.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "include": "#asun-fenced-code-block-backtick"
    },
    {
      "include": "#asun-fenced-code-block-tilde"
    }
  ],
  "repository": {
    "asun-fenced-code-block-backtick": {
      "begin": "(^|\\G)(\\s*)(`{3,})\\s*(?i:(asun))\\s*$",
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "beginCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        },
        "4": {
          "name": "fenced_code.block.language.markdown"
        }
      },
      "endCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        }
      },
      "name": "markup.fenced_code.block.markdown",
      "contentName": "meta.embedded.block.asun",
      "patterns": [
        {
          "include": "source.asun"
        }
      ]
    },
    "asun-fenced-code-block-tilde": {
      "begin": "(^|\\G)(\\s*)(~{3,})\\s*(?i:(asun))\\s*$",
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "beginCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        },
        "4": {
          "name": "fenced_code.block.language.markdown"
        }
      },
      "endCaptures": {
        "3": {
          "name": "punctuation.definition.markdown"
        }
      },
      "name": "markup.fenced_code.block.markdown",
      "contentName": "meta.embedded.block.asun",
      "patterns": [
        {
          "include": "source.asun"
        }
      ]
    }
  }
}